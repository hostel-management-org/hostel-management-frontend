# Dependencies – must never be committed (causes "Permission denied" on Linux CI)
node_modules/

# Production build output – generated by CI, not needed in source control
build/

# Environment variable files – may contain secrets
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Editor / OS artefacts
.DS_Store
Thumbs.db
.vscode/settings.json

# Debug logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
